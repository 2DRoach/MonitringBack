# ==== 1. СЕКРЕТЫ И КОНФИГИ (САМОЕ ВАЖНОЕ) ====
# Файл с паролями и ключами НИКОГДА не должен попасть в git
.env
*.env.local

# ==== 2. PYTHON ====
# Байт-код (мусор, создаваемый интерпретатором)
__pycache__/
*.py[cod]
*$py.class

# Виртуальное окружение (venv)
# Библиотеки не должны храниться в git, их скачивают через requirements.txt
venv/
env/
.venv/
ENV/

# ==== 3. IDE И РЕДАКТОРЫ ====
# Настройки VS Code, PyCharm и т.д. у каждого разработчика свои
.idea/
.vscode/
*.swp
*.swo
*~

# ==== 4. ТЕСТИРОВАНИЕ И ОТЧЕТЫ ====
.pytest_cache/
.coverage
htmlcov/

